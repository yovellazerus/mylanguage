# ============================================================
# Project
# ============================================================

PROJECT = mylanguge
TARGET  = bin/$(PROJECT).exe

# ============================================================
# Directories
# ============================================================

SRC_DIR = src
INC_DIR = inc
BIN_DIR = bin

# ============================================================
# Compiler
# ============================================================

CC = gcc
CFLAGS = -Wall -Wextra -std=c11 -I$(INC_DIR)

# ============================================================
# Files
# ============================================================

SRC = $(wildcard $(SRC_DIR)/*.c)
OBJ = $(patsubst $(SRC_DIR)/%.c,$(BIN_DIR)/%.o,$(SRC))

# ============================================================
# Build
# ============================================================

all: $(TARGET)

# Link
$(TARGET): $(OBJ)
	$(CC) $(OBJ) -o $(TARGET)

# Compile source files into bin folder
$(BIN_DIR)/%.o: $(SRC_DIR)/%.c
	$(CC) $(CFLAGS) -c $< -o $@

# ============================================================
# Clean
# ============================================================

clean:
	if exist "$(BIN_DIR)\*.o" del /Q "$(BIN_DIR)\*.o"
	if exist "$(BIN_DIR)\$(PROJECT).exe" del /Q "$(BIN_DIR)\$(PROJECT).exe"

# ============================================================
# Run
# ============================================================

run: $(TARGET)
	"$(TARGET)"

# ============================================================
# Rebuild
# ============================================================

rebuild: clean all